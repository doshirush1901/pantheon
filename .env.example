# =============================================================================
# IRA Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# =============================================================================
# REQUIRED: API Keys
# =============================================================================

# OpenAI - For LLM (GPT-4o) and fallback embeddings
OPENAI_API_KEY=sk-your-openai-key-here

# Voyage AI - For embeddings (voyage-3, 1024 dimensions)
# Get key at: https://www.voyageai.com/
VOYAGE_API_KEY=pa-your-voyage-key-here

# =============================================================================
# REQUIRED: Telegram Bot (for Telegram channel)
# =============================================================================

# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Your Telegram chat ID (for authorized access)
# Get via @userinfobot on Telegram
EXPECTED_CHAT_ID=your-telegram-chat-id

# =============================================================================
# OPTIONAL: Memory Service
# =============================================================================

# Mem0 - For enhanced long-term memory
# Get key at: https://mem0.ai/
MEM0_API_KEY=your-mem0-key-here

# Anthropic - For alternative LLM (Claude)
ANTHROPIC_API_KEY=your-anthropic-key-here

# =============================================================================
# INFRASTRUCTURE
# =============================================================================

# PostgreSQL Database (optional if using Mem0 only)
DATABASE_URL=postgresql://ira:ira_password@localhost:5432/ira_db

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_TIMEOUT=30

# Neo4j Graph Database (for knowledge relationships)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ira_knowledge_graph

# =============================================================================
# OPERATIONAL
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
IRA_LOG_LEVEL=INFO

# Log format and environment (used by observability/structured logging)
IRA_LOG_FORMAT=json
IRA_ENVIRONMENT=production

# LLM Models
DEFAULT_LLM_MODEL=gpt-4o
FAST_LLM_MODEL=gpt-4o-mini

# Feature flags
USE_MEM0=true
USE_VOYAGE=true
USE_BRAIN_ORCHESTRATOR=true
ENABLE_PROACTIVE=true
ENABLE_FEEDBACK_LEARNING=true
USE_POSTGRES=true
HYBRID_MODE=true
USE_UNIFIED_IDENTITY=true

# =============================================================================
# DASHBOARD & WEB APP
# =============================================================================

# Dashboard URL for Telegram Web App integration
# Set to your deployed dashboard URL (e.g., https://your-domain.com/dashboard)
IRA_DASHBOARD_URL=

# Dashboard server config (for local deployment)
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# Admin Telegram ID (for proactive notifications)
RUSHABH_TELEGRAM_ID=your-admin-telegram-id

# =============================================================================
# EMAIL CHANNEL (for OpenClaw Gateway)
# =============================================================================

# IMAP settings for email channel
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_USER=your-email@gmail.com
EMAIL_IMAP_PASSWORD=your-app-password

# =============================================================================
# CACHING
# =============================================================================

# Redis URL for distributed caching (optional - falls back to in-memory LRU)
REDIS_URL=redis://localhost:6379/0

# Cache settings
CACHE_DEFAULT_TTL=3600
EMBEDDING_CACHE_SIZE=10000
QUERY_CACHE_SIZE=1000

# =============================================================================
# EMBEDDING OPTIMIZATION
# =============================================================================

# Embedding model and batch settings
EMBEDDING_MODEL=voyage-3
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_CONCURRENT=4
EMBEDDING_DIMENSIONS=1024

# =============================================================================
# OBSERVABILITY & MONITORING
# =============================================================================

# Langfuse - LLM Observability Dashboard
# Create account at https://langfuse.com and get API keys
LANGFUSE_PUBLIC_KEY=pk-your-public-key
LANGFUSE_SECRET_KEY=sk-your-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# =============================================================================
# RATE LIMITING (requests per minute)
# =============================================================================

# Override default rate limits (optional)
OPENAI_RATE_LIMIT=60
VOYAGE_RATE_LIMIT=100
QDRANT_RATE_LIMIT=200
MEM0_RATE_LIMIT=60

# =============================================================================
# WEB RESEARCH (Iris agent)
# =============================================================================

# Jina AI - For web scraping and research (used by Iris, lead_intelligence, deep_research)
# Get key at: https://jina.ai/
JINA_API_KEY=your-jina-key-here

# =============================================================================
# ADVANCED: Reranker Configuration
# =============================================================================

# Reranker type: "flashrank" (faster, lighter) or "colbert" (more accurate)
RERANKER_TYPE=flashrank
